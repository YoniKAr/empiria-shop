# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# secrets / service-account keys — never commit
google-wallet-key.json
*-key.json
*.serviceaccount.json

# apple wallet cert material — never commit private keys / certs
*.key
*.p12
*.csr
*.cer
*.pem

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
